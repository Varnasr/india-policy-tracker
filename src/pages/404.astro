---
import Base from '../layouts/Base.astro';
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---
<Base title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="not-found">
    <span class="nf-code">404</span>
    <h2>Page Not Found</h2>
    <p>The policy or page you're looking for doesn't exist or may have been moved.</p>
    <div class="nf-links">
      <a href={base} class="btn btn-primary">Back to Dashboard</a>
      <a href={`${base}search/`} class="btn btn-secondary">Search Policies</a>
    </div>
  </div>
</Base>

<style>
  .not-found {
    text-align: center;
    padding: 80px 0;
  }
  .nf-code {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 5rem;
    font-weight: 800;
    color: var(--color-border);
    line-height: 1;
    display: block;
    margin-bottom: 8px;
  }
  .not-found h2 {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.5rem;
    color: var(--color-text);
    margin-bottom: 8px;
  }
  .not-found p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }
  .nf-links {
    display: flex;
    gap: 12px;
    justify-content: center;
  }
</style>
