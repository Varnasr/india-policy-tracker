---
import Base from '../layouts/Base.astro';
import StatsBar from '../components/StatsBar.astro';
import PolicyTimeline from '../components/PolicyTimeline.astro';
import ActivityHeatmap from '../components/ActivityHeatmap.astro';
import Insights from '../components/Insights.astro';
import Sidebar from '../components/Sidebar.astro';
import PolicyCard from '../components/PolicyCard.astro';
import TrendingStrip from '../components/TrendingStrip.astro';
import StoryClusters from '../components/StoryClusters.astro';
import NewsletterBar from '../components/NewsletterBar.astro';
import { getAllPolicies, getMeta } from '../lib/data';

const policies = getAllPolicies();
const meta = getMeta();
const INITIAL_SHOW = 20;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---
<Base title="Dashboard">
  {/* ── Hero / About ─────────────────────────────────── */}
  <div class="hero">
    <div class="hero-content">
      <h1 class="hero-title">PolicyDhara</h1>
      <p class="hero-tagline">An open-source tracker for Indian development policy — from gazette notifications to ground impact.</p>
      <p class="hero-desc">
        India's policy landscape is vast and fragmented across ministries, state governments, and regulatory bodies.
        PolicyDhara aggregates legislation, schemes, budget announcements, and policy notifications from official sources
        like the Press Information Bureau, gazette notifications, and ministry portals — making it possible to track
        what the government is doing, across sectors and over time.
      </p>
      <p class="hero-caveat">
        Coverage note: Digital government archives are more complete for recent years. Earlier eras (UPA and before) are underrepresented
        in this dataset due to limited online archival, not due to less policymaking. <a href={`${base}about/`}>Read methodology</a>
      </p>
      <div class="hero-features">
        <div class="hero-feature">
          <span class="hero-feature-icon">&#9670;</span>
          <div>
            <strong>Automated Collection</strong>
            <span>Pipeline fetches from 300+ official sources every 6 hours via GitHub Actions</span>
          </div>
        </div>
        <div class="hero-feature">
          <span class="hero-feature-icon">&#9670;</span>
          <div>
            <strong>Historical Depth</strong>
            <span>Coverage from 1990s liberalisation through UPA and NDA governments to present</span>
          </div>
        </div>
        <div class="hero-feature">
          <span class="hero-feature-icon">&#9670;</span>
          <div>
            <strong>Impact Tracking</strong>
            <span>Policies annotated with beneficiary reach, budgets, SDG alignment, and implementation status</span>
          </div>
        </div>
        <div class="hero-feature">
          <span class="hero-feature-icon">&#9670;</span>
          <div>
            <strong>Fully Open</strong>
            <span>All data and code on GitHub — built for researchers, journalists, and citizens</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <StatsBar
    totalPolicies={meta.total_policies}
    totalSources={meta.total_sources}
    totalSectors={meta.total_sectors}
    lastUpdated={meta.last_updated}
  />

  {/* ── Tab Navigation ─────────────────────────────────── */}
  <div class="tab-bar">
    <button class="tab-btn active" data-tab="overview">Overview</button>
    <button class="tab-btn" data-tab="browse">Browse Policies</button>
  </div>

  {/* ── Tab: Overview ──────────────────────────────────── */}
  <div class="tab-panel active" id="tab-overview">
    <TrendingStrip />
    <PolicyTimeline />
    <Insights />
    <StoryClusters />
    <ActivityHeatmap />

    {/* Recent highlights */}
    <div class="section-header">
      <h3>Recent Highlights</h3>
      <p>Latest policy actions across all sectors</p>
    </div>

    {/* Featured hero card */}
    {policies.length > 0 && (
      <div class="hero-card-wrap">
        <article class="hero-policy-card" data-type={policies[0].type}>
          <div class="hero-card-accent"></div>
          <div class="hero-card-body">
            <div class="hero-card-top">
              <span class={`policy-type type-${policies[0].type}`}>{policies[0].type}</span>
              <span class="policy-date">{new Date(policies[0].date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
              <span class="policy-source">{policies[0].source_short}</span>
            </div>
            <h3 class="hero-card-title">
              <a href={`${base}policies/${policies[0].id}/`}>{policies[0].title}</a>
            </h3>
            {policies[0].description && (
              <p class="hero-card-desc">{policies[0].description}</p>
            )}
            <div class="policy-sectors">
              {policies[0].sectors.map(s => (
                <a href={`${base}sectors/${s.toLowerCase().replace(/ & /g, '-').replace(/ /g, '-')}/`} class="sector-badge">{s}</a>
              ))}
            </div>
          </div>
        </article>
      </div>
    )}

    {/* Secondary cards — 2 medium */}
    {policies.length > 2 && (
      <div class="highlight-duo">
        {policies.slice(1, 3).map(p => (
          <PolicyCard id={p.id} title={p.title} description={p.description} link={p.link}
            date={p.date} source_short={p.source_short} sectors={p.sectors} type={p.type} />
        ))}
      </div>
    )}

    {/* Remaining cards — 3 column compact grid */}
    {policies.length > 5 && (
      <div class="highlight-trio">
        {policies.slice(3, 6).map(p => (
          <PolicyCard id={p.id} title={p.title} description={p.description} link={p.link}
            date={p.date} source_short={p.source_short} sectors={p.sectors} type={p.type} />
        ))}
      </div>
    )}
    <NewsletterBar />
    <div style="text-align:center; padding: var(--space-lg) 0;">
      <button class="btn btn-secondary" id="goto-browse">View All Policies &rarr;</button>
    </div>
  </div>

  {/* ── Tab: Browse ────────────────────────────────────── */}
  <div class="tab-panel" id="tab-browse">
    <div class="page-grid">
      <Sidebar
        sectorCounts={meta.sector_counts}
        sourceCounts={meta.source_counts}
      />
      <section>
        <div class="feed-toolbar">
          <div id="feed-status" aria-live="polite" style="font-size:0.75rem; color:var(--color-text-muted);"></div>
          <div class="feed-toolbar-actions">
            <button class="btn btn-secondary btn-sm" id="export-csv" title="Export visible policies as CSV">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              CSV
            </button>
            <button class="btn btn-secondary btn-sm" id="export-json" title="Export visible policies as JSON">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              JSON
            </button>
          </div>
        </div>
        <div class="policy-feed" id="policy-feed">
          {policies.length === 0 ? (
            <div class="empty-state">
              <h3>No policies fetched yet</h3>
              <p>Run the pipeline or wait for the next GitHub Actions run.</p>
            </div>
          ) : (
            policies.map((p, i) => (
              <div class={`policy-card-wrap ${i >= INITIAL_SHOW ? 'hidden-card' : ''}`}>
                <PolicyCard id={p.id} title={p.title} description={p.description} link={p.link}
                  date={p.date} source_short={p.source_short} sectors={p.sectors} type={p.type} />
              </div>
            ))
          )}
          {policies.length > INITIAL_SHOW && (
            <div class="show-more-wrap" id="show-more-wrap">
              <button class="btn btn-primary" id="show-more-btn">
                Show More <span id="remaining-count">({policies.length - INITIAL_SHOW} more)</span>
              </button>
            </div>
          )}
        </div>
        <div id="no-results" class="empty-state" style="display:none;">
          <h3>No matching policies</h3>
          <p>Try adjusting your search or filters.</p>
        </div>
      </section>
    </div>
  </div>

</Base>

<style>
  /* ── Hero ───────────────────────────────────── */
  .hero {
    margin-bottom: var(--space-xl);
    background: linear-gradient(135deg, var(--color-bg-white) 0%, var(--color-bg-alt) 100%);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl) var(--space-xl);
    box-shadow: var(--shadow-card);
  }
  .hero-title {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 6px;
    line-height: 1.1;
  }
  .hero-tagline {
    font-size: 1rem;
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: var(--space-md);
    line-height: 1.4;
  }
  .hero-desc {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 720px;
    margin-bottom: var(--space-lg);
  }
  .hero-caveat {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 8px 12px;
    margin-bottom: var(--space-md);
    line-height: 1.5;
  }
  .hero-caveat a {
    color: var(--color-accent);
    font-weight: 600;
  }
  .hero-features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .hero-feature {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }
  .hero-feature strong {
    display: block;
    font-size: 0.8125rem;
    color: var(--color-text);
    font-weight: 700;
    margin-bottom: 1px;
  }
  .hero-feature-icon {
    color: var(--color-accent);
    font-size: 0.5rem;
    margin-top: 5px;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .hero { padding: var(--space-lg); }
    .hero-title { font-size: 1.5rem; }
    .hero-features { grid-template-columns: 1fr; }
  }

  /* ── Tabs ───────────────────────────────────── */
  .tab-bar {
    display: flex;
    gap: 2px;
    border-bottom: 2px solid var(--color-border);
    margin-bottom: var(--space-xl);
    overflow-x: auto;
  }
  .tab-btn {
    padding: 12px 20px;
    background: none;
    border: none;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-muted);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    transition: all 0.15s;
    white-space: nowrap;
    text-decoration: none;
  }
  .tab-btn:hover { color: var(--color-text); }
  .tab-btn.active {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  .section-header {
    margin-bottom: var(--space-lg);
  }
  .section-header h3 {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 4px;
  }
  .section-header p {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  /* ── Hero Card (featured first policy) ── */
  .hero-card-wrap {
    margin-bottom: 16px;
  }
  .hero-policy-card {
    background: var(--color-bg-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: all 0.2s ease;
    position: relative;
  }
  .hero-policy-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }
  .hero-card-accent {
    height: 4px;
    background: linear-gradient(90deg, var(--color-accent) 0%, var(--type-legislation) 50%, var(--type-scheme) 100%);
  }
  .hero-card-body {
    padding: 28px 32px;
  }
  .hero-card-top {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
    font-size: 0.75rem;
  }
  .hero-card-title {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.375rem;
    font-weight: 700;
    line-height: 1.35;
    color: var(--color-text);
    margin-bottom: 10px;
  }
  .hero-card-title a {
    color: inherit;
    text-decoration: none;
  }
  .hero-card-title a:hover {
    color: var(--color-accent);
  }
  .hero-card-desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin-bottom: 14px;
    max-width: 800px;
  }

  /* ── Highlight duo (2-col medium cards) ── */
  .highlight-duo {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-bottom: 16px;
  }
  .highlight-duo .policy-card {
    padding: 20px;
  }
  .highlight-duo .policy-title {
    font-size: 1rem;
  }

  /* ── Highlight trio (3-col compact cards) ── */
  .highlight-trio {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-bottom: var(--space-xl);
  }
  .highlight-trio .policy-card {
    padding: 16px;
  }
  .highlight-trio .policy-title {
    font-size: 0.8125rem;
  }
  .highlight-trio .policy-description {
    display: none;
  }

  @media (max-width: 768px) {
    .highlight-duo { grid-template-columns: 1fr; }
    .highlight-trio { grid-template-columns: 1fr; }
    .hero-card-body { padding: 20px; }
    .hero-card-title { font-size: 1.125rem; }
  }

  .feed-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-md);
    padding: 8px 12px;
    background: var(--color-bg-alt);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border-light);
  }
  .feed-toolbar-actions {
    display: flex;
    gap: 6px;
  }
  .btn-sm {
    padding: 6px 12px !important;
    font-size: 0.6875rem !important;
    gap: 4px !important;
  }

  .policy-card-wrap { display: contents; }
  .hidden-card > .policy-card { display: none; }

  @media (max-width: 768px) {
    .tab-btn { padding: 10px 14px; font-size: 0.8125rem; }
  }
</style>

<script define:vars={{ INITIAL_SHOW }}>
  document.addEventListener('DOMContentLoaded', () => {
    // ── Tab switching ──
    const tabBtns = document.querySelectorAll('.tab-btn:not(.tab-link)');
    const tabPanels = document.querySelectorAll('.tab-panel');

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        tabBtns.forEach(b => b.classList.remove('active'));
        tabPanels.forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        const panel = document.getElementById('tab-' + btn.dataset.tab);
        if (panel) panel.classList.add('active');
      });
    });

    // "View All Policies" button on Overview tab
    const gotoBrowse = document.getElementById('goto-browse');
    if (gotoBrowse) {
      gotoBrowse.addEventListener('click', () => {
        tabBtns.forEach(b => b.classList.remove('active'));
        tabPanels.forEach(p => p.classList.remove('active'));
        const browseBtn = document.querySelector('[data-tab="browse"]');
        const browsePanel = document.getElementById('tab-browse');
        if (browseBtn) browseBtn.classList.add('active');
        if (browsePanel) browsePanel.classList.add('active');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    // ── Feed filtering (Browse tab) ──
    const wraps = Array.from(document.querySelectorAll('.policy-card-wrap'));
    const cards = wraps.map(w => w.querySelector('.policy-card'));
    const searchInput = document.getElementById('policy-search');
    const noResults = document.getElementById('no-results');
    const feedStatus = document.getElementById('feed-status');
    const showMoreBtn = document.getElementById('show-more-btn');
    const showMoreWrap = document.getElementById('show-more-wrap');
    const remainingCount = document.getElementById('remaining-count');

    let showCount = INITIAL_SHOW;
    let activeSector = 'all';
    let activeType = 'all';
    let activeSource = 'all';
    let searchQuery = '';
    let isFiltering = false;

    function applyFilters() {
      let visibleCount = 0;
      let totalMatching = 0;
      isFiltering = activeSector !== 'all' || activeType !== 'all' || activeSource !== 'all' || searchQuery !== '';

      for (let i = 0; i < cards.length; i++) {
        const card = cards[i];
        if (!card) continue;
        const sectors = JSON.parse(card.dataset.sectors || '[]');
        const type = card.dataset.type || '';
        const source = card.dataset.source || '';
        const text = card.textContent?.toLowerCase() || '';

        const matches = (activeSector === 'all' || sectors.includes(activeSector))
          && (activeType === 'all' || type === activeType)
          && (activeSource === 'all' || source === activeSource)
          && (!searchQuery || text.includes(searchQuery.toLowerCase()));

        if (matches) {
          totalMatching++;
          if (isFiltering || totalMatching <= showCount) {
            card.style.display = '';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        } else {
          card.style.display = 'none';
        }
      }

      if (noResults) noResults.style.display = visibleCount === 0 ? '' : 'none';
      if (feedStatus) feedStatus.textContent = `Showing ${visibleCount} of ${cards.length} policies`;

      if (showMoreWrap) {
        if (isFiltering || showCount >= cards.length) {
          showMoreWrap.style.display = 'none';
        } else {
          const remaining = totalMatching - showCount;
          showMoreWrap.style.display = remaining > 0 ? '' : 'none';
          if (remainingCount && remaining > 0) remainingCount.textContent = `(${remaining} more)`;
        }
      }
    }

    if (showMoreBtn) showMoreBtn.addEventListener('click', () => { showCount += 20; applyFilters(); });

    document.querySelectorAll('.sector-filter').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.sector-filter').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeSector = btn.dataset.sector || 'all';
        applyFilters();
      });
    });

    document.querySelectorAll('.type-filter').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.type-filter').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeType = btn.dataset.type || 'all';
        applyFilters();
      });
    });

    document.querySelectorAll('.source-filter').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.source-filter').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeSource = btn.dataset.source || 'all';
        applyFilters();
      });
    });

    if (searchInput) {
      let timer;
      searchInput.addEventListener('input', () => {
        clearTimeout(timer);
        timer = setTimeout(() => { searchQuery = searchInput.value; applyFilters(); }, 200);
      });
    }

    applyFilters();

    // ── Export ──
    function getVisiblePolicies() {
      const visible = [];
      for (let i = 0; i < cards.length; i++) {
        const card = cards[i];
        if (!card || card.style.display === 'none') continue;
        visible.push({
          id: card.dataset.id || '',
          title: card.querySelector('.policy-title')?.textContent?.trim() || '',
          type: card.dataset.type || '',
          source: card.dataset.source || '',
          date: card.dataset.date || '',
          sectors: JSON.parse(card.dataset.sectors || '[]'),
          description: card.querySelector('.policy-description')?.textContent?.trim() || '',
        });
      }
      return visible;
    }

    function downloadFile(content, filename, mimeType) {
      const blob = new Blob([content], { type: mimeType });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      a.click();
      URL.revokeObjectURL(url);
    }

    document.getElementById('export-csv')?.addEventListener('click', () => {
      const rows = getVisiblePolicies();
      if (rows.length === 0) return;
      const headers = ['id', 'title', 'type', 'source', 'date', 'sectors', 'description'];
      const csv = [headers.join(',')].concat(
        rows.map(r => headers.map(h => {
          let v = h === 'sectors' ? r[h].join('; ') : r[h];
          return '"' + String(v).replace(/"/g, '""') + '"';
        }).join(','))
      ).join('\n');
      downloadFile(csv, `policydhara-export-${new Date().toISOString().slice(0,10)}.csv`, 'text/csv');
    });

    document.getElementById('export-json')?.addEventListener('click', () => {
      const rows = getVisiblePolicies();
      if (rows.length === 0) return;
      downloadFile(JSON.stringify(rows, null, 2), `policydhara-export-${new Date().toISOString().slice(0,10)}.json`, 'application/json');
    });
  });
</script>
