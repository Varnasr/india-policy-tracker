---
import Base from '../layouts/Base.astro';
import StatsBar from '../components/StatsBar.astro';
import Sidebar from '../components/Sidebar.astro';
import PolicyCard from '../components/PolicyCard.astro';
import { getAllPolicies, getMeta } from '../lib/data';

const policies = getAllPolicies();
const meta = getMeta();
---
<Base title="Dashboard">
  <StatsBar
    totalPolicies={meta.total_policies}
    totalSources={meta.total_sources}
    totalSectors={meta.total_sectors}
    lastUpdated={meta.last_updated}
  />

  <div class="page-grid">
    <Sidebar
      sectorCounts={meta.sector_counts}
      sourceCounts={meta.source_counts}
    />

    <section class="policy-feed" id="policy-feed">
      <div id="feed-status" class="visually-hidden" aria-live="polite"></div>

      {policies.length === 0 ? (
        <div class="empty-state">
          <h3>No policies fetched yet</h3>
          <p>Run <code>python3 scripts/fetch_all.py</code> to fetch the latest policies, or wait for the next GitHub Actions run.</p>
        </div>
      ) : (
        policies.map(p => (
          <PolicyCard
            id={p.id}
            title={p.title}
            description={p.description}
            link={p.link}
            date={p.date}
            source_short={p.source_short}
            sectors={p.sectors}
            type={p.type}
          />
        ))
      )}

      <div id="no-results" class="empty-state" style="display:none;">
        <h3>No matching policies</h3>
        <p>Try adjusting your search or filters.</p>
      </div>
    </section>
  </div>

  <script>
    // ── Client-side filtering & search ──────────────────────────
    document.addEventListener('DOMContentLoaded', () => {
      const cards = Array.from(document.querySelectorAll('.policy-card')) as HTMLElement[];
      const searchInput = document.getElementById('policy-search') as HTMLInputElement;
      const noResults = document.getElementById('no-results') as HTMLElement;
      const feedStatus = document.getElementById('feed-status') as HTMLElement;

      let activeSector = 'all';
      let activeType = 'all';
      let activeSource = 'all';
      let searchQuery = '';

      function applyFilters() {
        let visibleCount = 0;

        for (const card of cards) {
          const sectors = JSON.parse(card.dataset.sectors || '[]') as string[];
          const type = card.dataset.type || '';
          const source = card.dataset.source || '';
          const text = card.textContent?.toLowerCase() || '';

          const matchSector = activeSector === 'all' || sectors.includes(activeSector);
          const matchType = activeType === 'all' || type === activeType;
          const matchSource = activeSource === 'all' || source === activeSource;
          const matchSearch = !searchQuery || text.includes(searchQuery.toLowerCase());

          if (matchSector && matchType && matchSource && matchSearch) {
            card.style.display = '';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        }

        noResults.style.display = visibleCount === 0 ? '' : 'none';
        feedStatus.textContent = `Showing ${visibleCount} of ${cards.length} policies`;
      }

      // Sector filters
      document.querySelectorAll('.sector-filter').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.sector-filter').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          activeSector = (btn as HTMLElement).dataset.sector || 'all';
          applyFilters();
        });
      });

      // Type filters
      document.querySelectorAll('.type-filter').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.type-filter').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          activeType = (btn as HTMLElement).dataset.type || 'all';
          applyFilters();
        });
      });

      // Source filters
      document.querySelectorAll('.source-filter').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.source-filter').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          activeSource = (btn as HTMLElement).dataset.source || 'all';
          applyFilters();
        });
      });

      // Search
      if (searchInput) {
        let debounceTimer: ReturnType<typeof setTimeout>;
        searchInput.addEventListener('input', () => {
          clearTimeout(debounceTimer);
          debounceTimer = setTimeout(() => {
            searchQuery = searchInput.value;
            applyFilters();
          }, 200);
        });
      }
    });
  </script>
</Base>
