---
import Base from '../../layouts/Base.astro';
import PolicyCard from '../../components/PolicyCard.astro';
import { getAllPolicies, getMeta, getSectorSlug } from '../../lib/data';

export function getStaticPaths() {
  const meta = getMeta();
  return Object.keys(meta.sector_counts).map(sector => ({
    params: { sector: getSectorSlug(sector) },
    props: { sectorName: sector }
  }));
}

const { sector } = Astro.params;
const { sectorName } = Astro.props;

const policies = getAllPolicies().filter(p => p.sector_slugs.includes(sector!));
const base = import.meta.env.BASE_URL;
---
<Base title={sectorName} description={`Tracking Indian government policies in ${sectorName} — ${policies.length} policies from open sources.`}>
  <div style="padding: var(--space-xl) 0;">
    <div style="margin-bottom: var(--space-xl);">
      <a href={`${base}sectors/`} style="font-size: 0.8125rem; color: var(--color-text-muted);">&larr; All Sectors</a>
      <h2 class="page-title" style="margin-top: var(--space-sm);">{sectorName}</h2>
      <p class="page-subtitle">
        {policies.length} {policies.length === 1 ? 'policy' : 'policies'} tracked
      </p>
    </div>

    <div class="policy-feed">
      {policies.length === 0 ? (
        <div class="empty-state">
          <h3>No policies in this sector yet</h3>
          <p>Policies will appear here after the next data fetch.</p>
        </div>
      ) : (
        policies.map(p => (
          <PolicyCard
            id={p.id}
            title={p.title}
            description={p.description}
            link={p.link}
            date={p.date}
            source_short={p.source_short}
            sectors={p.sectors}
            type={p.type}
          />
        ))
      )}
    </div>
  </div>
</Base>
