---
import Base from '../../layouts/Base.astro';
import { getMeta, getSectorSlug } from '../../lib/data';

const meta = getMeta();

const sectors = Object.entries(meta.sector_counts).sort((a, b) => b[1] - a[1]);
const base = import.meta.env.BASE_URL;
---
<Base title="Sectors" description="Browse Indian development policies by sector — 22 themes covering education, health, agriculture, climate, digital, finance, and more.">
  <div style="padding: var(--space-xl) 0;">
    <h2 class="page-title">Development Sectors</h2>
    <p class="page-subtitle">
      Browse policies across {sectors.length} development themes.
    </p>

    <div class="sector-grid">
      {sectors.map(([name, count]) => (
        <a href={`${base}sectors/${getSectorSlug(name)}/`} class="sector-card">
          <span class="sector-card-name">{name}</span>
          <span class="sector-card-count">{count} {count === 1 ? 'policy' : 'policies'}</span>
        </a>
      ))}
    </div>
  </div>
</Base>
