---
import Base from '../../layouts/Base.astro';
import { getMeta } from '../../lib/data';
import fs from 'node:fs';
import path from 'node:path';

const meta = getMeta();

let feedsConfig: any = { sources: {} };
try {
  const raw = fs.readFileSync(path.join(process.cwd(), 'feeds.json'), 'utf-8');
  feedsConfig = JSON.parse(raw);
} catch {}

const sourceEntries = Object.entries(meta.source_counts).sort((a, b) => b[1] - a[1]);
---
<Base title="Sources" description="Open data sources powering the PolicyDhara — PIB, PRS, India Code, eGazette, NITI Aayog, data.gov.in, and more.">
  <div style="padding: var(--space-xl) 0;">
    <h2 class="page-title">Data Sources</h2>
    <p class="page-subtitle">
      Aggregating open data from {sourceEntries.length} sources, fetched automatically every 6 hours.
    </p>

    <div class="sector-grid">
      {sourceEntries.map(([shortName, count]) => {
        const sourceConfig = Object.values(feedsConfig.sources || {}).find((s: any) => s.short_name === shortName) as any;
        const description = sourceConfig?.description || '';
        const type = sourceConfig?.type || 'unknown';

        return (
          <div class="sector-card" style="cursor: default;">
            <div style="display: flex; justify-content: space-between; align-items: center; gap: 8px;">
              <span class="sector-card-name">{shortName}</span>
              <span class={`policy-type type-${type === 'rss' ? 'announcement' : type === 'api' ? 'research' : 'policy'}`} style="font-size: 0.5625rem; flex-shrink: 0;">
                {type.toUpperCase()}
              </span>
            </div>
            {description && <span style="font-size: 0.8125rem; color: var(--color-text-muted); line-height: 1.5;">{description}</span>}
            <span style="font-size: 0.8125rem; font-weight: 600; color: var(--color-accent);">{count} {count === 1 ? 'item' : 'items'}</span>
          </div>
        );
      })}
    </div>
  </div>
</Base>
