---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;
---
<Base title="About" description="About the India Policy Tracker — an open-source, auto-updating tool for tracking Indian development policies across 22 sectors.">
  <div style="max-width: 680px; padding: var(--space-xl) 0;">
    <h2 class="page-title">About</h2>

    <div style="display: flex; flex-direction: column; gap: var(--space-lg); color: var(--color-text-secondary); font-size: 0.9375rem; line-height: 1.8;">
      <p>
        <strong style="color: var(--color-text);">India Policy Tracker</strong> is an open-source, auto-updating
        dashboard that aggregates Indian government policies, legislation, notifications, and research
        across <strong style="color: var(--color-text);">22 development sectors</strong> from
        <strong style="color: var(--color-text);">20+ verified open sources</strong>.
      </p>

      <p>
        Built as a complement to <a href="https://www.impactmojo.in">ImpactMojo</a>'s development economics
        education platform, this tracker aims to make Indian policymaking more transparent and accessible
        to researchers, students, practitioners, and citizens.
      </p>

      <div style="background: var(--color-bg-white); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-lg);">
        <h3 style="font-family: 'Source Serif 4', Georgia, serif; font-size: 1rem; color: var(--color-text); margin-bottom: var(--space-md);">How It Works</h3>
        <ol style="padding-left: var(--space-lg); display: flex; flex-direction: column; gap: var(--space-sm);">
          <li><strong style="color: var(--color-text);">Automated Fetching:</strong> Every 6 hours, GitHub Actions runs Python scripts that pull data from RSS feeds, APIs, and web scraping.</li>
          <li><strong style="color: var(--color-text);">Smart Classification:</strong> Each policy item is classified into relevant development sectors using keyword-based NLP.</li>
          <li><strong style="color: var(--color-text);">Static Generation:</strong> The site is rebuilt with Astro after each fetch, producing a fast static site.</li>
          <li><strong style="color: var(--color-text);">Zero Cost:</strong> The entire pipeline runs on free tiers (GitHub Actions + GitHub Pages).</li>
        </ol>
      </div>

      <div style="background: var(--color-bg-white); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-lg);">
        <h3 style="font-family: 'Source Serif 4', Georgia, serif; font-size: 1rem; color: var(--color-text); margin-bottom: var(--space-md);">Data Sources</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-md); font-size: 0.8125rem;">
          <div>
            <h4 style="color: var(--color-text); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-xs);">Official Government</h4>
            <ul style="list-style: none; display: flex; flex-direction: column; gap: 2px;">
              <li>Press Information Bureau</li>
              <li>India Code</li>
              <li>eGazette of India</li>
              <li>NITI Aayog</li>
              <li>Digital Sansad</li>
              <li>data.gov.in</li>
              <li>Reserve Bank of India</li>
            </ul>
          </div>
          <div>
            <h4 style="color: var(--color-text); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-xs);">Research & International</h4>
            <ul style="list-style: none; display: flex; flex-direction: column; gap: 2px;">
              <li>PRS Legislative Research</li>
              <li>World Bank India</li>
              <li>Observer Research Foundation</li>
              <li>Centre for Policy Research</li>
            </ul>
          </div>
        </div>
      </div>

      <div style="background: var(--color-bg-white); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-lg);">
        <h3 style="font-family: 'Source Serif 4', Georgia, serif; font-size: 1rem; color: var(--color-text); margin-bottom: var(--space-sm);">Subscribe</h3>
        <p>Get updates via our <a href={`${base}rss.xml`}>RSS feed</a> in your favourite reader.</p>
      </div>

      <div>
        <h3 style="font-family: 'Source Serif 4', Georgia, serif; font-size: 1rem; color: var(--color-text); margin-bottom: var(--space-sm);">Open Source</h3>
        <p>
          This project is fully open source. Contributions and bug reports are welcome
          on <a href="https://github.com/Varnasr/india-policy-tracker">GitHub</a>.
        </p>
        <p style="margin-top: var(--space-sm);">
          Built with <a href="https://astro.build">Astro</a>, Python, and GitHub Actions.
          A project by <a href="https://www.impactmojo.in">ImpactMojo</a>.
        </p>
      </div>
    </div>
  </div>
</Base>
