---
import { getImpactForPolicy, getPriority } from '../lib/data';

interface Props {
  id: string;
  title: string;
  description?: string;
  link?: string;
  date: string;
  source_short: string;
  sectors: string[];
  type: string;
}

const { id, title, description, link, date, source_short, sectors, type } = Astro.props;
const impact = getImpactForPolicy(title);
const priority = getPriority({ id, title, description: description || '', link: link || '', date, source_id: '', source_name: '', source_short, sectors, sector_slugs: [], type });
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const detailHref = `${base}policies/${id}/`;

function getSectorSlug(sector: string): string {
  return sector.toLowerCase().replace(/ & /g, '-').replace(/ /g, '-');
}

function formatDate(dateStr: string): string {
  try {
    return new Date(dateStr).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
  } catch { return dateStr; }
}

function getRelativeTime(dateStr: string): string {
  try {
    const d = new Date(dateStr);
    const now = new Date();
    const diffDays = Math.floor((now.getTime() - d.getTime()) / (1000 * 60 * 60 * 24));
    if (diffDays === 0) return 'Today';
    if (diffDays === 1) return 'Yesterday';
    if (diffDays < 7) return `${diffDays}d ago`;
    if (diffDays < 30) return `${Math.floor(diffDays / 7)}w ago`;
    return formatDate(dateStr);
  } catch { return dateStr; }
}
---
<article class="policy-card" data-sectors={JSON.stringify(sectors.map(getSectorSlug))} data-type={type} data-source={source_short} data-date={date} data-id={id}>
  <button class="bookmark-btn" data-policy-id={id} title="Bookmark this policy (B)">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2z"/></svg>
  </button>
  <div class="policy-card-header">
    <h3 class="policy-title">
      <a href={detailHref}>{title}</a>
    </h3>
  </div>

  <div class="policy-meta">
    {priority !== 'normal' && (
      <span class={`priority-badge priority-${priority}`}>
        {priority === 'critical' ? '●' : priority === 'high' ? '▲' : '◆'} {priority}
      </span>
    )}
    <span class="policy-date" title={formatDate(date)}>{getRelativeTime(date)}</span>
    <span class="meta-dot"></span>
    <span class="policy-source">{source_short}</span>
    <span class={`policy-type type-${type}`}>{type}</span>
  </div>

  {description && (
    <p class="policy-description">{description}</p>
  )}

  {impact && (
    <div class="policy-impact-bar">
      <span class="impact-badge" style={`background: var(${impact.impact_score >= 8 ? '--type-scheme-bg' : impact.impact_score >= 6 ? '--type-notification-bg' : '--color-bg-alt'}); color: var(${impact.impact_score >= 8 ? '--type-scheme' : impact.impact_score >= 6 ? '--type-notification' : '--color-text-muted'});`}>
        Impact {impact.impact_score}/10
      </span>
      <span class="impact-beneficiaries">{impact.beneficiaries}</span>
      <span class="impact-impl-tag" style={`color: ${impact.implementation === 'operational' ? '#166534' : impact.implementation === 'partial' ? '#c2410c' : '#854d0e'};`}>
        {impact.implementation === 'operational' ? 'Operational' : impact.implementation === 'partial' ? 'Partial' : impact.implementation === 'early' ? 'Early Stage' : 'Announced'}
      </span>
    </div>
  )}

  <div class="policy-sectors">
    {sectors.map(sector => (
      <a href={`${base}sectors/${getSectorSlug(sector)}/`} class="sector-badge">
        {sector}
      </a>
    ))}
  </div>
</article>
