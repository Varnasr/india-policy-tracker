---
import { getSourceTypeCounts } from '../lib/data';

interface Props {
  sectorCounts: Record<string, number>;
  sourceCounts: Record<string, number>;
  activeSector?: string;
  activeSource?: string;
}

const { sectorCounts, sourceCounts, activeSector, activeSource } = Astro.props;
const sourceTypeCounts = getSourceTypeCounts();

function getSectorSlug(sector: string): string {
  return sector.toLowerCase().replace(/ & /g, '-').replace(/ /g, '-');
}

const TYPE_OPTIONS = [
  { key: 'all', label: 'All' },
  { key: 'legislation', label: 'Legislation' },
  { key: 'notification', label: 'Notification' },
  { key: 'scheme', label: 'Scheme' },
  { key: 'budget', label: 'Budget' },
  { key: 'research', label: 'Research' },
  { key: 'announcement', label: 'Announcement' },
  { key: 'policy', label: 'Policy' },
];

const SOURCE_TYPE_OPTIONS = [
  { key: 'all', label: 'All Types', icon: '◈' },
  { key: 'government', label: 'Government', icon: '🏛' },
  { key: 'regulator', label: 'Regulator', icon: '📋' },
  { key: 'legal', label: 'Legal', icon: '⚖' },
  { key: 'think_tank', label: 'Think Tank', icon: '🔬' },
  { key: 'media', label: 'Media', icon: '📰' },
  { key: 'international', label: 'International', icon: '🌐' },
];

const sortedSectors = Object.entries(sectorCounts).sort((a, b) => b[1] - a[1]);
---
<aside class="sidebar">
  <!-- Search -->
  <div class="search-box">
    <span class="search-icon">&#128269;</span>
    <input type="search" class="search-input" id="policy-search" placeholder="Search policies..." />
  </div>

  <!-- Type Filter — pill style -->
  <div class="filter-section">
    <h3>Filter by Type</h3>
    <div class="filter-pills">
      {TYPE_OPTIONS.map(t => (
        <button class={`filter-pill type-filter ${t.key === 'all' ? 'active' : ''}`} data-type={t.key}>
          {t.label}
        </button>
      ))}
    </div>
  </div>

  <!-- Sector Filter -->
  <div class="filter-section">
    <h3>Sectors</h3>
    <button class={`filter-btn sector-filter ${!activeSector ? 'active' : ''}`} data-sector="all">
      All Sectors
      <span class="filter-count">{Object.values(sectorCounts).reduce((a, b) => a + b, 0)}</span>
    </button>
    {sortedSectors.map(([sector, count]) => (
      <button class={`filter-btn sector-filter ${activeSector === getSectorSlug(sector) ? 'active' : ''}`} data-sector={getSectorSlug(sector)}>
        {sector}
        <span class="filter-count">{count}</span>
      </button>
    ))}
  </div>

  <!-- Source Type Filter -->
  <div class="filter-section">
    <h3>Source Type</h3>
    <div class="filter-pills">
      {SOURCE_TYPE_OPTIONS.map(t => (
        <button class={`filter-pill source-type-filter ${t.key === 'all' ? 'active' : ''}`} data-source-type={t.key}>
          {t.icon} {t.label}
          {t.key !== 'all' && sourceTypeCounts[t.key] ? <span class="pill-count">{sourceTypeCounts[t.key]}</span> : null}
        </button>
      ))}
    </div>
  </div>

  <!-- Source Filter -->
  <div class="filter-section">
    <h3>Sources</h3>
    <button class="filter-btn source-filter active" data-source="all">
      All Sources
    </button>
    {Object.entries(sourceCounts).sort((a, b) => b[1] - a[1]).map(([source, count]) => (
      <button class={`filter-btn source-filter ${activeSource === source ? 'active' : ''}`} data-source={source}>
        {source}
        <span class="filter-count">{count}</span>
      </button>
    ))}
  </div>
</aside>
