---
---
<div class="newsletter-bar">
  <div class="newsletter-text">
    <h4>PolicyDhara Daily Brief</h4>
    <p>Get the day's policy actions delivered to your inbox every morning.</p>
  </div>
  <form class="newsletter-form" id="newsletter-form" action="https://buttondown.com/api/emails/embed-subscribe/policydhara" method="post" target="popupwindow">
    <input type="email" name="email" class="newsletter-input" placeholder="your@email.com" required id="newsletter-email" />
    <button type="submit" class="newsletter-submit" id="newsletter-btn">Subscribe</button>
  </form>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('newsletter-form') as HTMLFormElement;
    const btn = document.getElementById('newsletter-btn') as HTMLButtonElement;
    const input = document.getElementById('newsletter-email') as HTMLInputElement;

    if (form) {
      form.addEventListener('submit', () => {
        // Buttondown handles the actual subscription via form action.
        // We just update the UI optimistically.
        setTimeout(() => {
          if (btn && input) {
            btn.textContent = 'Subscribed!';
            btn.style.background = '#16a34a';
            input.disabled = true;
            btn.disabled = true;
            localStorage.setItem('pd-newsletter-sub', input.value);
          }
        }, 300);
      });

      // Check if already subscribed
      const sub = localStorage.getItem('pd-newsletter-sub');
      if (sub && btn && input) {
        btn.textContent = 'Subscribed';
        btn.style.background = '#16a34a';
        input.value = sub;
        input.disabled = true;
        btn.disabled = true;
      }
    }
  });
</script>
