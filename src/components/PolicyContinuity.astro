---
import { getPolicyContinuityChains } from '../lib/data';

const chains = getPolicyContinuityChains();

const ERA_COLORS: Record<string, string> = {
  'Pre-UPA': '#737373',
  'UPA I': '#f97316',
  'UPA II': '#ea580c',
  'NDA I': '#3b82f6',
  'NDA II': '#1d4ed8',
  'NDA III': '#2563eb',
};
---

<div class="continuity-section">
  <div class="continuity-header">
    <h3>Policy Continuity Tracker</h3>
    <p>How India's key policies have evolved across governments — tracing lineage, rebranding, and genuine transformation</p>
  </div>

  <div class="chains-container">
    {chains.map(chain => (
      <details class="chain-card">
        <summary class="chain-summary">
          <div class="chain-title-row">
            <span class="chain-theme">{chain.theme}</span>
            <span class="chain-sector-tag">{chain.sector}</span>
          </div>
          <div class="chain-preview">
            {chain.timeline.map((step, i) => (
              <span class="chain-dot-wrap">
                <span class="chain-dot" style={`background: ${ERA_COLORS[step.era] || '#737373'}; ${step.status === 'active' ? 'box-shadow: 0 0 0 2px #fff, 0 0 0 3px ' + (ERA_COLORS[step.era] || '#737373') + ';' : ''}`}></span>
                {i < chain.timeline.length - 1 && <span class="chain-connector"></span>}
              </span>
            ))}
            <span class="chain-year-range">
              {chain.timeline[0].year} &ndash; {chain.timeline[chain.timeline.length - 1].status === 'active' ? 'Present' : chain.timeline[chain.timeline.length - 1].year}
            </span>
          </div>
        </summary>

        <div class="chain-body">
          <div class="timeline">
            {chain.timeline.map((step, i) => (
              <div class={`timeline-step ${step.status === 'active' ? 'step-active' : 'step-superseded'}`}>
                <div class="step-marker">
                  <span class="step-dot" style={`background: ${ERA_COLORS[step.era] || '#737373'};`}></span>
                  {i < chain.timeline.length - 1 && <span class="step-line"></span>}
                </div>
                <div class="step-content">
                  <div class="step-header">
                    <span class="step-name">{step.name}</span>
                    <span class="step-year">{step.year}</span>
                  </div>
                  <div class="step-meta">
                    <span class="step-era" style={`color: ${ERA_COLORS[step.era] || '#737373'};`}>{step.era}</span>
                    <span class="step-party">{step.party}</span>
                    <span class={`step-status step-status-${step.status}`}>
                      {step.status === 'active' ? 'Active' : 'Superseded'}
                    </span>
                  </div>
                  <p class="step-desc">{step.description}</p>
                </div>
              </div>
            ))}
          </div>

          <div class="chain-analysis">
            <h5>Analysis</h5>
            <p>{chain.analysis}</p>
          </div>
        </div>
      </details>
    ))}
  </div>

  <div class="continuity-legend">
    {Object.entries(ERA_COLORS).map(([era, color]) => (
      <span class="legend-item">
        <span class="legend-dot" style={`background: ${color};`}></span>
        {era}
      </span>
    ))}
  </div>
</div>

<style>
  .continuity-section {
    margin-bottom: var(--space-2xl);
  }
  .continuity-header {
    margin-bottom: var(--space-lg);
  }
  .continuity-header h3 {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 4px;
  }
  .continuity-header p {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .chains-container {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* Chain card */
  .chain-card {
    background: var(--color-bg-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: box-shadow 0.2s;
  }
  .chain-card[open] {
    box-shadow: var(--shadow-card-hover);
  }

  .chain-summary {
    padding: 16px 20px;
    cursor: pointer;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .chain-summary::-webkit-details-marker { display: none; }
  .chain-summary::marker { display: none; content: ''; }

  .chain-title-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .chain-theme {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .chain-card:hover .chain-theme { color: var(--color-accent); }
  .chain-sector-tag {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    padding: 2px 8px;
    background: var(--color-bg-alt);
    border-radius: var(--radius-pill);
    color: var(--color-text-muted);
  }

  .chain-preview {
    display: flex;
    align-items: center;
    gap: 0;
  }
  .chain-dot-wrap {
    display: flex;
    align-items: center;
  }
  .chain-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .chain-connector {
    width: 20px;
    height: 2px;
    background: var(--color-border);
  }
  .chain-year-range {
    margin-left: 12px;
    font-size: 0.6875rem;
    color: var(--color-text-dim);
  }

  /* Timeline body */
  .chain-body {
    padding: 0 20px 20px;
  }

  .timeline {
    display: flex;
    flex-direction: column;
  }

  .timeline-step {
    display: flex;
    gap: 16px;
  }

  .step-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 20px;
  }
  .step-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
    z-index: 1;
  }
  .step-active .step-dot {
    box-shadow: 0 0 0 3px var(--color-bg-white), 0 0 0 4px currentColor;
  }
  .step-line {
    width: 2px;
    flex: 1;
    background: var(--color-border);
    min-height: 20px;
  }

  .step-content {
    flex: 1;
    padding-bottom: 20px;
  }
  .step-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .step-name {
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--color-text);
  }
  .step-superseded .step-name {
    color: var(--color-text-muted);
  }
  .step-year {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-text-dim);
    font-family: 'SF Mono', 'Consolas', monospace;
  }

  .step-meta {
    display: flex;
    gap: 8px;
    align-items: center;
    margin: 4px 0 8px;
  }
  .step-era {
    font-size: 0.6875rem;
    font-weight: 700;
  }
  .step-party {
    font-size: 0.625rem;
    color: var(--color-text-dim);
  }
  .step-status {
    font-size: 0.5625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 1px 6px;
    border-radius: var(--radius-pill);
  }
  .step-status-active { background: #dcfce7; color: #166534; }
  .step-status-superseded { background: #f3f4f6; color: #6b7280; }

  .step-desc {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* Analysis box */
  .chain-analysis {
    background: var(--color-bg-alt);
    border-radius: var(--radius-md);
    padding: 16px;
    margin-top: 8px;
    border-left: 3px solid var(--color-accent);
  }
  .chain-analysis h5 {
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    font-weight: 600;
    margin-bottom: 6px;
  }
  .chain-analysis p {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  /* Legend */
  .continuity-legend {
    display: flex;
    gap: 16px;
    margin-top: 16px;
    padding: 12px 16px;
    background: var(--color-bg-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    flex-wrap: wrap;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.625rem;
    color: var(--color-text-muted);
  }
  .legend-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  @media (max-width: 768px) {
    .chain-summary { padding: 12px 14px; }
    .chain-body { padding: 0 14px 14px; }
    .step-name { font-size: 0.8125rem; }
  }
</style>
