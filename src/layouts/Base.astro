---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Auto-updating tracker of Indian development policies across 20+ sectors. Open data, open source." } = Astro.props;
const siteTitle = `${title} | India Policy Tracker`;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{siteTitle}</title>
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:title" content={siteTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="India Policy Tracker" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:wght@400;600;700&display=swap" rel="stylesheet" />

  <!-- RSS Feed -->
  <link rel="alternate" type="application/rss+xml" title="India Policy Tracker RSS" href={`${base}rss.xml`} />

  <style>
    @import '../styles/global.css';
  </style>
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href={base} class="site-logo">
        <div class="logo-mark">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
        </div>
        <div>
          <h1>India Policy Tracker</h1>
          <span class="subtitle">by ImpactMojo</span>
        </div>
      </a>
      <nav class="header-nav">
        <a href={base}>Home</a>
        <a href={`${base}sectors/`}>Sectors</a>
        <a href={`${base}sources/`}>Sources</a>
        <a href={`${base}about/`}>About</a>
        <a href={`${base}rss.xml`} class="nav-rss" title="RSS Feed">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><circle cx="6.18" cy="17.82" r="2.18"/><path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/></svg>
          RSS
        </a>
      </nav>
    </div>
  </header>

  <main class="container">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-inner">
        <div class="footer-brand">
          <strong>India Policy Tracker</strong>
          <span>Open-source policy intelligence by <a href="https://www.impactmojo.in">ImpactMojo</a></span>
        </div>
        <div class="footer-links">
          <a href={`${base}about/`}>About</a>
          <a href={`${base}sectors/`}>Sectors</a>
          <a href={`${base}rss.xml`}>RSS</a>
          <a href="https://github.com/Varnasr/india-policy-tracker">GitHub</a>
        </div>
      </div>
      <div class="footer-bottom">
        Data from PIB, PRS Legislative Research, India Code, eGazette, NITI Aayog, data.gov.in, RBI, World Bank, ORF, and more.
        Auto-updated every 6 hours via GitHub Actions.
      </div>
    </div>
  </footer>
</body>
</html>
